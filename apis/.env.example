# APIS Environment Configuration
# Copy to .env and fill in real values.
# NEVER commit the real .env file.

# ── Application ────────────────────────────────────────────────────────────────
APIS_ENV=development
APIS_DEBUG=false
APIS_LOG_LEVEL=INFO

# Operating mode: research | backtest | paper | human_approved | restricted_live
APIS_OPERATING_MODE=research

# ── Database (PostgreSQL) ───────────────────────────────────────────────────────
APIS_DB_URL=postgresql+psycopg://user:password@localhost:5432/apis

# ── Cache (Redis) ───────────────────────────────────────────────────────────────
APIS_REDIS_URL=redis://localhost:6379/0

# ── Broker — Alpaca ─────────────────────────────────────────────────────────────
ALPACA_API_KEY=YOUR_ALPACA_API_KEY
ALPACA_API_SECRET=YOUR_ALPACA_API_SECRET
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── API server ──────────────────────────────────────────────────────────────────
APIS_API_HOST=0.0.0.0
APIS_API_PORT=8000

# ── Risk controls (overridable defaults — see risk_engine for hard-coded floors) ─
APIS_MAX_POSITIONS=15
APIS_DAILY_LOSS_LIMIT_PCT=0.02
APIS_WEEKLY_DRAWDOWN_LIMIT_PCT=0.05
APIS_MAX_SINGLE_NAME_PCT=0.20
APIS_MAX_SECTOR_PCT=0.40
APIS_MAX_THEMATIC_PCT=0.75

# ── Feature flags ───────────────────────────────────────────────────────────────
APIS_KILL_SWITCH=false

# ── Phase 57 — Insider / Smart-Money Flow Signal ───────────────────────────────
# Leave APIS_ENABLE_INSIDER_FLOW_STRATEGY=false until a backtest-validated
# provider is chosen AND the readiness-report gate passes.  Setting it true
# without a configured provider lets the strategy run but with neutral signal.
APIS_ENABLE_INSIDER_FLOW_STRATEGY=false
# Provider selection: null | quiverquant | sec_edgar | composite
APIS_INSIDER_FLOW_PROVIDER=null
# QuiverQuant REST API key (primary congressional / 13F source — paid).
APIS_QUIVERQUANT_API_KEY=
# SEC EDGAR requires an identifying User-Agent on all programmatic access.
# Format: "<App Name> <contact-email>".  Leave empty to disable EDGAR calls.
APIS_SEC_EDGAR_USER_AGENT=

# ── Admin / Ops ─────────────────────────────────────────────────────────────────
# Bearer token for POST /api/v1/admin/invalidate-secrets and GET /api/v1/admin/events.
# Leave empty to disable admin endpoints entirely.
APIS_ADMIN_ROTATION_TOKEN=

# ── Database connection pool (production tuning) ────────────────────────────────
APIS_DB_POOL_SIZE=5
APIS_DB_MAX_OVERFLOW=10
APIS_DB_POOL_RECYCLE=1800
APIS_DB_POOL_TIMEOUT=30

# ── Grafana ─────────────────────────────────────────────────────────────────
# Required — no default.  Change this before first run; do NOT use a weak password.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_BEFORE_DEPLOY

# ── Alertmanager / Notifications ────────────────────────────────────────────────
# Slack Incoming Webhook URL — set to enable alert notifications.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/WITH/YOUR_WEBHOOK
# Slack channel for critical (severity=critical) alerts.
SLACK_CHANNEL_CRITICAL=#apis-critical
# Slack channel for warning / default alerts.
SLACK_CHANNEL_DEFAULT=#apis-alerts
# PagerDuty Events API v2 integration key — set to enable critical paging.
PAGERDUTY_INTEGRATION_KEY=REPLACE_WITH_YOUR_PD_KEY

# ── Operator Webhook Alerts (Phase 31) ────────────────────────────────────────
# Full HTTPS URL of your operator webhook receiver (Slack, Teams, custom endpoint).
# Leave empty to disable all webhook delivery.
APIS_WEBHOOK_URL=
# Optional HMAC-SHA256 signing secret.  When set, every POST includes
# X-APIS-Signature: sha256=<hex> so the receiver can verify authenticity.
APIS_WEBHOOK_SECRET=
# Per-event-type flags — set to false to suppress individual alert types.
APIS_ALERT_ON_KILL_SWITCH=true
APIS_ALERT_ON_PAPER_CYCLE_ERROR=true
APIS_ALERT_ON_BROKER_AUTH_EXPIRY=true
APIS_ALERT_ON_DAILY_EVALUATION=true
