# APIS — Environment Variables Template
#
# Copy this file to .env and fill in all values before first run.
# .env is loaded automatically by Docker Compose and pydantic-settings.
# NEVER commit .env to version control — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APIS_ENV=development                    # development | staging | production
APIS_OPERATING_MODE=paper               # research | backtest | paper | human_approved
APIS_LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
APIS_KILL_SWITCH=false                  # set to "true" to halt all trading immediately

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=apis
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=apis
APIS_DB_URL=postgresql+psycopg://apis:change_me_in_production@postgres:5432/apis

# ── Cache / Redis ─────────────────────────────────────────────────────────────
APIS_REDIS_URL=redis://redis:6379/0

# ── Risk Controls (override defaults if needed) ───────────────────────────────
# APIS_MAX_POSITIONS=10
# APIS_DAILY_LOSS_LIMIT_PCT=0.02
# APIS_WEEKLY_DRAWDOWN_LIMIT_PCT=0.05
# APIS_MAX_SINGLE_NAME_PCT=0.20

# ── Broker: Alpaca Paper Trading ──────────────────────────────────────────────
# Required for Alpaca paper/live trading.  Get keys at: https://alpaca.markets/
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true                       # true for paper, false for live

# ── Broker: Charles Schwab ────────────────────────────────────────────────────
# Required for Schwab paper/live trading.
# Run the browser OAuth flow once to create schwab_token.json before connecting.
SCHWAB_API_KEY=
SCHWAB_APP_SECRET=
SCHWAB_ACCOUNT_HASH=                    # encrypted account hash from Schwab API
SCHWAB_TOKEN_PATH=/secrets/schwab_token.json
SCHWAB_CALLBACK_URL=https://127.0.0.1

# ── Broker: IBKR (Interactive Brokers) ───────────────────────────────────────
# IB Gateway / TWS must be running.  Paper port: 7497, Live port: 7496.
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# ── Secrets Backend ───────────────────────────────────────────────────────────
# "env" — reads secrets from env vars (default, suitable for K8s Secrets)
# "aws" — reads from AWS Secrets Manager (requires AWS_REGION + AWS_SECRET_NAME)
APIS_SECRET_BACKEND=env

# AWS Secrets Manager (only needed when APIS_SECRET_BACKEND=aws)
AWS_REGION=us-east-1
AWS_SECRET_NAME=apis/production/secrets
# AWS_ACCESS_KEY_ID=        # prefer IAM role / instance profile over static keys
# AWS_SECRET_ACCESS_KEY=

# ── Admin / Operations ────────────────────────────────────────────────────────
# Required to enable POST /api/v1/admin/invalidate-secrets (AWS rotation hook).
# Generate a strong random token: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty to disable the endpoint (default).
APIS_ADMIN_ROTATION_TOKEN=

# ── Monitoring: Grafana ───────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me

# ── Monitoring: Prometheus ────────────────────────────────────────────────────
# Prometheus scrapes from apis_api:8000/metrics automatically via docker-compose.
# Override only if running outside Docker.
# PROMETHEUS_PORT=9090
